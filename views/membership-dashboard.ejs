<!DOCTYPE html>
<html lang="en">
<head>
  <title>Membership Dashboard - OSM Helper</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css?v=<%= new Date().getTime() %>">
</head>
<body>
  <div class="container">
    <h1><%= groupName %> Membership Dashboard</h1>
    <p class="fetched-at">Data updated: <%= dataUpdated %></p>

    <button id="toggle-initials" type="button">Show leader initials</button>

    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Section</th>
            <th>Members</th>
            <th>Leaders</th>
            <th>Young Leaders</th>
            <th>Capacity</th>
            <th>Spaces</th>
            <th>Waiting List</th>
            <th class="initials-col" style="display:none;">Leader Initials</th>
            <th class="initials-col" style="display:none;">Young Leader Initials</th>
          </tr>
        </thead>
        <tbody>
          <% Object.keys(grouped).forEach(groupName => { const group = grouped[groupName]; %>
            <tr class="section-header">
              <td colspan="9"><%= groupName %></td>
            </tr>
            <% group.sections.forEach(sec => { %>
              <tr>
                <td><%= sec.name %></td>
                <td><%= sec.members %></td>
                <td><%= sec.leaders %></td>
                <td><%= sec.youngLeaders %></td>
                <td><%= sec.capacity %></td>
                <td><%= sec.spaces %></td>
                <td><%= sec.waiting %></td>
                <td class="initials-col" style="display:none;"><%= sec.leaderInitials %></td>
                <td class="initials-col" style="display:none;"><%= sec.youngLeaderInitials %></td>
              </tr>
            <% }) %>
            <tr class="subtotal">
              <td><strong><%= groupName %> subtotal</strong></td>
              <td><strong><%= group.subtotalMembers %></strong></td>
              <td><strong><%= group.subtotalLeaders %></strong></td>
              <td><strong><%= group.subtotalYLs %></strong></td>
              <td><strong><%= group.subtotalCapacity %></strong></td>
              <td><strong><%= group.subtotalSpaces %></strong></td>
              <td><strong><%= group.subtotalWaiting %></strong></td>
              <td class="initials-col" style="display:none;">&nbsp;</td>
              <td class="initials-col" style="display:none;">&nbsp;</td>
            </tr>
          <% }) %>

          <tr class="grand-total">
            <td><strong>Grand total</strong></td>
            <td><strong><%= totalMembers %></strong></td>
            <td><strong><%= totalLeaders %></strong></td>
            <td><strong><%= totalYLs %></strong></td>
            <td><strong><%= totalCapacity %></strong></td>
            <td><strong><%= totalSpaces %></strong></td>
            <td><strong><%= totalWaiting %></strong></td>
            <td class="initials-col" style="display:none;">&nbsp;</td>
            <td class="initials-col" style="display:none;">&nbsp;</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2>Waiting list overview</h2>
    <ul>
      <li>Of section age: <strong><%= ofAge %></strong></li>
      <li>Too young: <strong><%= tooYoungWaiting %></strong></li>
      <li>Total tracked (incl. explorers aged out): <strong><%= totalWaitingFull %></strong></li>
    </ul>

    <details>
      <summary>Debug details</summary>
      <pre><%= JSON.stringify(debugSummary, null, 2) %></pre>
    </details>

    <a href="/" class="back-button"><button>Back to Dashboard</button></a>
  </div>

  <script>
    (function () {
      const toggleBtn = document.getElementById('toggle-initials');
      const initialsColumns = Array.from(document.querySelectorAll('.initials-col'));
      let shown = false;

      if (!toggleBtn) return;

      toggleBtn.addEventListener('click', () => {
        shown = !shown;
        initialsColumns.forEach(cell => {
          cell.style.display = shown ? '' : 'none';
        });
        toggleBtn.textContent = shown ? 'Hide leader initials' : 'Show leader initials';
      });
    })();
  </script>
</body>
</html>
